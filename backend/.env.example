# ============================================
# SPLUNK INTEGRATION
# ============================================
SPLUNK_ENABLED=false
SPLUNK_URL=https://splunk.example.com:8089
SPLUNK_USERNAME=your_splunk_username
SPLUNK_PASSWORD=your_splunk_password
SPLUNK_SSL_VERIFY=false
# Sync schedule in minutes (0 = disabled, */60 = every 60 minutes)
SPLUNK_SYNC_SCHEDULE=*/60

# ============================================
# ELASTICSEARCH INTEGRATION
# ============================================
ELASTICSEARCH_ENABLED=false
ELASTICSEARCH_URL=https://elasticsearch.example.com:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=your_elastic_password
ELASTICSEARCH_SSL_VERIFY=false
ELASTICSEARCH_DETECTION_INDEX=.detections-default
# Sync schedule in minutes
ELASTICSEARCH_SYNC_SCHEDULE=*/15

# ============================================
# WEBHOOK CONFIGURATION
# ============================================
WEBHOOK_ENABLED=true
WEBHOOK_SECRET=your-secure-webhook-secret-key-here
WEBHOOK_TIMEOUT=30

# ============================================
# SOAR INTEGRATION
# ============================================
SOAR_ENABLED=false
SOAR_WEBHOOK_URL=
SOAR_API_KEY=
SOAR_TIMEOUT=20
SOAR_SSL_VERIFY=false

# ============================================
# THREAT INTELLIGENCE FEED
# ============================================
THREAT_INTEL_ENABLED=false
THREAT_INTEL_FEED_URL=
THREAT_INTEL_API_KEY=
THREAT_INTEL_SOURCE=threat-feed
THREAT_INTEL_TIMEOUT=20
THREAT_INTEL_SSL_VERIFY=false
THREAT_INTEL_SYNC_SCHEDULE=*/30

# ============================================
# API CONFIGURATION
# ============================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# ============================================
# DATABASE
# ============================================
DATABASE_URL=postgresql://user:password@db:5432/mydatabase
DATABASE_NAME=mydatabase
DATABASE_USER=user
DATABASE_PASSWORD=password

# ============================================
# REDIS
# ============================================
REDIS_URL=redis://redis:6379
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=django-db

# ============================================
# JWT/AUTH
# ============================================
SECRET_KEY=your-django-secret-key-change-this
JWT_SECRET=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
